    "react-native-nitro-modules": "^0.36.1",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^57.0.0",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.5",
